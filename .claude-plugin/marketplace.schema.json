{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "name": { "type": "string" },
    "version": { "type": "string" },
    "description": { "type": "string" },
    "owner": { "type": "object", "properties": { "name": { "type": "string" }, "email": { "type": "string" } } },
    "plugins": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "source": { "type": "string" },
          "category": { "type": "string" },
          "version": { "type": "string" },
          "author": { "type": "object" }
        }
      }
    }
  }
}
