{
  "name": "ollama-code-cli",
  "version": "2.4.0",
  "description": "Local-first coding assistant using Ollama — no cloud API",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "ollama-code": "bin/ollama-code.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node bin/ollama-code.js",
    "build": "cd ui && npm run build",
    "postinstall": "node scripts/postinstall.js",
    "version:show": "node bin/ollama-code.js --version"
  },
  "keywords": [
    "ollama",
    "cli",
    "code",
    "local",
    "ai"
  ],
  "license": "MIT",
  "dependencies": {
    "qrcode-terminal": "^0.12.0"
  }
}
